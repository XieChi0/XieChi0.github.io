// Prisma 风格数据模型文档。实际数据库托管在 Supabase。
// 请保持此文件与 docs/studyProgress/supabase-schema.sql 同步。

// 表1：用户对某篇文章的当前阅读进度
model StudyProgress {
  id              String   @id @default(uuid()) // 主键
  userId          String   @map("user_id") // 用户ID，对应 Supabase auth.users.id
  articleId       String   @map("article_id") // 文章slug，如 "个人/护肤"
  articleSource   String   @default("posts") @map("article_source") // 来源：posts 或 external
  articleTitle    String   @default("") @map("article_title") // 标题快照
  articleUrl      String   @default("") @map("article_url") // 文章URL
  progressPercent Int      @default(0) @map("progress_percent") // 进度 0-100
  status          String   @default("not_started") @map("status") // not_started | reading | completed
  lastReadAt      DateTime? @map("last_read_at") // 上次阅读时间
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([userId, articleSource, articleId])
  @@map("study_progress")
}

// 表2：进度变更日志（只追加，用于每日复盘）
model StudyEvent {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  articleId        String   @map("article_id")
  articleSource    String   @default("posts") @map("article_source")
  articleTitle     String   @default("") @map("article_title")
  previousPercent  Int      @default(0) @map("previous_percent") // 变化前进度
  currentPercent   Int      @default(0) @map("current_percent") // 变化后进度
  eventDate        DateTime @default(now()) @map("event_date") // 日期桶，用于按天汇总
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("study_events")
}

// 表3：学习目标（如 "6月30日前学完AI专题"）
model StudyGoal {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  title      String // 目标标题
  topic      String   @default("") // 主题名，用于分组
  targetDate DateTime? @map("target_date") // 截止日期
  status     String   @default("active") @map("status") // active | paused | completed | archived
  notes      String   @default("") // 备注
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  items      StudyGoalItem[]
  @@map("study_goals")
}

// 表4：目标关联的文章（一个目标可包含多篇文章）
model StudyGoalItem {
  id            String   @id @default(uuid())
  userId        String   @map("user_id") // 冗余存储，简化RLS和查询
  goalId        String   @map("goal_id") // 所属目标ID
  articleId     String   @map("article_id")
  articleSource String   @default("posts") @map("article_source")
  articleTitle  String   @default("") @map("article_title")
  articleUrl    String   @default("") @map("article_url")
  targetPercent Int      @default(100) @map("target_percent") // 目标进度，通常100
  sortOrder     Int      @default(0) @map("sort_order") // 排序
  createdAt     DateTime @default(now()) @map("created_at")

  goal          StudyGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  @@unique([goalId, articleSource, articleId])
  @@map("study_goal_items")
}

// 表5：文章切片（预留，未来知识库问答用，可配 embedding）
model ArticleChunk {
  id            String   @id @default(uuid())
  articleId     String   @map("article_id")
  articleSource String   @default("posts") @map("article_source")
  articleTitle  String   @default("") @map("article_title")
  chunkIndex    Int      @default(0) @map("chunk_index") // 切片序号
  content       String // 切片文本
  metadata      Json     @default("{}") @map("metadata") // 元数据
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([articleSource, articleId, chunkIndex])
  @@map("article_chunks")
}
