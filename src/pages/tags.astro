---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getTagList } from "@utils/content-utils";
import { getTagUrl } from "@utils/url-utils";

const tags = await getTagList();
---

<MainGridLayout title="Tags" description="Tags">
    <div class="card-base px-8 py-6">
        <div class="mb-6">
            <h1 class="text-2xl font-bold text-75">
                Tags
            </h1>
            <p class="text-sm text-50 mt-1">
                {tags.length} {tags.length === 1 ? 'tag' : 'tags'}
            </p>
        </div>
        
        <div class="flex flex-wrap gap-3">
            {tags.map(tag => (
                <a 
                    href={getTagUrl(tag.name)}
                    class="inline-flex items-center gap-2 px-4 py-2 rounded-full 
                           bg-[var(--btn-plain-bg-hover)] hover:bg-[var(--primary)]
                           text-75 hover:text-[var(--card-bg)] transition-colors duration-200"
                >
                    <span class="font-medium">#{tag.name.trim()}</span>
                    <span class="text-sm opacity-70">({tag.count})</span>
                </a>
            ))}
        </div>
        
        {tags.length === 0 && (
            <p class="text-50 text-center py-8">
                No tags found.
            </p>
        )}
    </div>
</MainGridLayout>
