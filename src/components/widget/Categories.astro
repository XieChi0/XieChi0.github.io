<!-- 这个文件负责渲染博客侧边栏中的"分类"小部件。原来只能渲染单级，改造后支持任意多层级递归渲染 -->
---
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { type CategoryNode, getCategoryTree } from "../../utils/content-utils";
import WidgetLayout from "./WidgetLayout.astro";

const categoryTree = await getCategoryTree();

const COLLAPSED_HEIGHT = "7.5rem";
const COLLAPSE_THRESHOLD = 5;

// 递归计算总分类数（支持任意层级）
function countAllCategories(nodes: CategoryNode[]): number {
	let count = 0;
	nodes.forEach((node) => {
		count += 1;
		if (node.children && node.children.length > 0) {
			count += countAllCategories(node.children);
		}
	});
	return count;
}

// 递归渲染分类树节点，返回 HTML 字符串
// indent 是缩进深度，每深入一层增加 1.25rem
function renderCategoryNodes(nodes: CategoryNode[], indent = 0): string {
	return nodes
		.map((node) => {
			const paddingLeft = `${0.75 + indent * 1.25}rem`;
			const hasChildren = node.children && node.children.length > 0;

			if (hasChildren) {
				// 有子分类：用 details 折叠
				return `
                <details class="category-parent" >
                    <summary class="category-summary">
                        <svg class="category-icon" width="14" height="14" viewBox="0 0 14 14" fill="none">
                            <path d="M7 0L8.5 5.5L14 7L8.5 8.5L7 14L5.5 8.5L0 7L5.5 5.5L7 0Z" fill="currentColor"/>
                        </svg>
                        <a href="${node.url}" class="category-link">${node.name.trim()}</a>
                        <span class="category-count">${node.count}</span>
                        <span class="category-arrow">
                            <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                                <path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                    </summary>
                    <div class="category-children">
                        ${renderCategoryNodes(node.children ?? [], indent + 1)}
                    </div>
                </details>
            `;
			}
			// 叶子节点：普通链接按钮样式，无图标
			return `
                <a href="${node.url}" class="category-leaf" style="padding-left: ${paddingLeft}">
                    <span class="leaf-name">${node.name.trim()}</span>
                    <span class="category-count">${node.count}</span>
                </a>
            `;
		})
		.join("");
}

const totalCategories = countAllCategories(categoryTree);
const isCollapsed = totalCategories >= COLLAPSE_THRESHOLD;
const categoryTreeHtml = renderCategoryNodes(categoryTree);

interface Props {
	class?: string;
	style?: string;
}
const className = Astro.props.class;
const style = Astro.props.style;
---

<WidgetLayout name={i18n(I18nKey.categories)} id="categories" isCollapsed={isCollapsed} collapsedHeight={COLLAPSED_HEIGHT}
                class={className} style={style}
>
    <div class="category-tree" set:html={categoryTreeHtml}></div>
</WidgetLayout>

<style is:global>
    .category-tree {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        width: 100%;
        box-sizing: border-box;
    }

    .category-parent {
        border: none;
        padding: 0;
        background: transparent;
        width: 100%;
        padding-left: var(--indent, 0rem);
        border-radius: 0.5rem;
    }

    .category-summary {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-basis: 100%;
        box-sizing: border-box;
        border-radius: 0.5rem;
        cursor: pointer;
        list-style: none;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        padding: 0.5rem 0.625rem;
    }

    .category-summary:hover {
        background-color: var(--btn-plain-bg-hover);
    }

    .category-summary::-webkit-details-marker {
        display: none;
    }

    .category-icon {
        width: 1rem;
        height: 1rem;
        color: var(--primary);
        margin-right: 0.6rem;
        flex-shrink: 0;
        transition: all 0.2s;
        opacity: 0.7;
    }

    .category-summary:hover .category-icon {
        opacity: 1;
        transform: scale(1.1);
    }

    .category-arrow {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.25rem;
        height: 1.25rem;
        color: var(--text-tertiary);
        transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        flex-shrink: 0;
    }

    details[open] > .category-summary .category-arrow {
        transform: rotate(180deg);
    }

    .category-link {
        flex: 1;
        font-weight: 500;
        font-size: 0.9375rem;
        color: var(--text-primary);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .category-link:hover {
        color: var(--primary);
    }

    .category-count {
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--text-tertiary);
        background-color: var(--badge-bg);
        padding: 0.125rem 0.5rem;
        border-radius: 0.25rem;
        margin-left: 0.5rem;
        flex-shrink: 0;
        transition: all 0.2s;
    }

    .category-summary:hover .category-count,
    .category-leaf:hover .category-count {
        background-color: var(--primary);
        color: white;
    }

    .category-children {
        display: flex;
        flex-direction: column;
        gap: 0.125rem;
        border-left: 1px dashed var(--border);
        padding-left: 1rem;
        /* margin-left: 0.6rem; */
        width: 100%;
        box-sizing: border-box;
        flex-basis: 100%;
        animation: slideDown 0.2s ease-out;
    }

    @keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-8px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .category-leaf {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-basis: 100%;
        box-sizing: border-box;
        border-radius: 0.375rem;
        text-decoration: none;
        color: var(--text-secondary);
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        padding: 0.375rem 0.5rem;
        font-size: 0.875rem;
    }

    .category-leaf:hover {
        background-color: var(--btn-plain-bg-hover);
        color: var(--primary);
        transform: translateX(2px);
    }

    .category-leaf:hover .category-count {
        background-color: var(--primary);
        color: white;
    }

    .leaf-name {
        font-weight: 400;
    }
</style>
